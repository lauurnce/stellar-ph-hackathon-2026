# Stellar Network
NEXT_PUBLIC_STELLAR_RPC_URL=https://soroban-testnet.stellar.org
NEXT_PUBLIC_STELLAR_NETWORK=TESTNET
NEXT_PUBLIC_STELLAR_NETWORK_PASSPHRASE=Test SDF Network ; September 2015

# Soroban Contract
# Get this after running: .\scripts\deploy-testnet.ps1
NEXT_PUBLIC_SOROBAN_CONTRACT_ID=

# Read Address
# A funded Stellar testnet account used for read-only contract simulations
# Fund via: https://friendbot.stellar.org
NEXT_PUBLIC_STELLAR_READ_ADDRESS=

# USDC Asset on Testnet
# Testnet USDC issuer (Circle's testnet issuer)
NEXT_PUBLIC_SOROBAN_ASSET_ADDRESS=
NEXT_PUBLIC_SOROBAN_ASSET_CODE=USDC
NEXT_PUBLIC_SOROBAN_ASSET_DECIMALS=7

# Block Explorer
NEXT_PUBLIC_STELLAR_EXPLORER_URL=https://stellar.expert/explorer/testnet
